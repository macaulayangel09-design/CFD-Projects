import numpy as np
import matplotlib.pyplot as plt
 
nx = 41
dx = 2 / (nx - 1)
nt = 25
dt = 0.025
c = 1
 
x = np.linspace(0, 2, nx)
 
u = np.ones(nx)
u[int(0.5/dx):int(1/dx + 1)] = 2
 
plt.figure()
 
for n in range(nt):
   un = u.copy()
   
   for i in range(1, nx):
       u[i] = un[i] - c * dt/dx * (un[i] - un[i-1])
   
   
   plt.clf()
   plt.plot(x, u)
   plt.ylim(0.5, 2.5)
   plt.title(f"1-D Linear Convection at time step: {n}")
   plt.pause(0.1)
 
plt.show()





